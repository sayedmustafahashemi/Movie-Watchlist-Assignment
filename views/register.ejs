<%- include('partials/header') %>

<div class="min-h-[80vh] flex items-center justify-center">
    <div class="max-w-md w-full">
        <div class="bg-white/80 backdrop-blur-sm rounded-3xl shadow-2xl p-8 border border-white/50">
            <div class="text-center mb-8">
                <div class="inline-flex p-4 bg-gradient-to-r from-purple-600 to-pink-600 rounded-3xl shadow-xl mb-4">
                    <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-1 .05 1.16.84 2 1.87 2 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                </div>
                <h2 class="text-4xl font-bold gradient-text">Join the club</h2>
                <p class="text-gray-500 mt-2">Start your movie journey today</p>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
                    <% errors.forEach(function(error) { %>
                        <p class="text-red-700 text-sm">• <%= error.msg %></p>
                    <% }); %>
                </div>
            <% } %>
            
            <form action="/auth/register" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">USERNAME</label>
                    <input type="text" name="username" class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="cinema_lover" required>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">EMAIL</label>
                    <input type="email" name="email" class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="hello@moviecube.com" required>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">PASSWORD</label>
                    <input type="password" name="password" class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-purple-500" placeholder="min. 6 characters" required>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">CONFIRM PASSWORD</label>
                    <input type="password" name="password2" class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-purple-500" required>
                </div>
                
                <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-500 text-white py-3.5 rounded-2xl font-bold hover:shadow-2xl hover:scale-105 transition-all duration-300 mt-6">
                    Create Account →
                </button>
            </form>
            
            <p class="text-center mt-6 text-gray-500 text-sm">
            Already have an account? 
            <a href="/login" class="text-purple-600 font-bold hover:text-purple-700 transition">Sign in</a>
            </p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>