<%- include('../partials/header') %>

<!-- Stats Section -->
<% if (movies.length > 0) { 
    const totalMovies = movies.length;
    const totalRatings = movies.reduce((sum, m) => sum + m.rating, 0);
    const avgRating = (totalRatings / totalMovies).toFixed(1);
    const watchedMovies = movies.filter(m => m.watchStatus === 'watched').length;
%>
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
    <div class="bg-gradient-to-br from-purple-600 to-purple-800 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-purple-200 text-sm">Total Movies</p>
                <p class="text-4xl font-bold mt-2"><%= totalMovies %></p>
            </div>
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M4 5h16v2H4V5zm0 4h16v2H4V9zm0 4h16v2H4v-2zm0 4h10v2H4v-2z"/></svg>
        </div>
    </div>
    <div class="bg-gradient-to-br from-pink-600 to-rose-800 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-pink-200 text-sm">Avg Rating</p>
                <p class="text-4xl font-bold mt-2"><%= avgRating %></p>
            </div>
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        </div>
    </div>
    <div class="bg-gradient-to-br from-emerald-600 to-teal-800 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-emerald-200 text-sm">Watched</p>
                <p class="text-4xl font-bold mt-2"><%= watchedMovies %></p>
            </div>
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        </div>
    </div>
    <div class="bg-gradient-to-br from-orange-600 to-amber-800 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-orange-200 text-sm">Watchlist</p>
                <p class="text-4xl font-bold mt-2"><%= movies.filter(m => m.watchStatus === 'planning').length %></p>
            </div>
            <svg class="w-8 h-8 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        </div>
    </div>
</div>
<% } %>

<!-- Header -->
<div class="flex justify-between items-center mb-8 flex-wrap gap-4">
    <div>
        <h1 class="text-5xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">My Collection</h1>
        <p class="text-gray-400 mt-2"><%= movies.length %> films curated with passion</p>
    </div>
    <a href="/movies/new" class="group inline-flex items-center gap-2 px-6 py-3.5 bg-gradient-to-r from-purple-600 to-pink-500 text-white rounded-2xl font-bold hover:shadow-2xl hover:scale-105 transition-all duration-300">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Movie
    </a>
</div>

<% if (success_msg) { %>
    <div class="bg-emerald-600/20 border border-emerald-500/30 text-emerald-400 px-5 py-4 rounded-2xl mb-6 text-sm">
        ✨ <%= success_msg %>
    </div>
<% } %>

<% if (movies.length === 0) { %>
    <div class="bg-gray-800/50 backdrop-blur-sm rounded-3xl p-16 text-center border-2 border-dashed border-gray-700">
        <div class="text-7xl mb-4">🎬</div>
        <h3 class="text-2xl font-bold text-gray-300 mb-2">Your cinema awaits</h3>
        <p class="text-gray-400 mb-6">Start building your curated movie collection</p>
        <a href="/movies/new" class="inline-block px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white rounded-2xl font-bold hover:shadow-xl transition-all">
            Add Your First Movie
        </a>
    </div>
<% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% movies.forEach(function(movie) { %>
            <div class="group relative bg-gray-800 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden hover:-translate-y-2 border border-gray-700">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-500 via-pink-500 to-orange-500 transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
                
                <!-- Movie Poster Section -->
                <% if (movie.posterPath) { %>
                    <div class="relative h-56 overflow-hidden bg-gray-900">
                        <img src="https://image.tmdb.org/t/p/w400<%= movie.posterPath %>" 
                             alt="<%= movie.title %>"
                             class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                        <div class="absolute top-3 right-3">
                            <span class="px-3 py-1.5 rounded-xl text-xs font-bold shadow-lg 
                                <% if (movie.watchStatus === 'watched') { %>bg-emerald-600 text-white
                                <% } else if (movie.watchStatus === 'favorite') { %>bg-amber-600 text-white
                                <% } else { %>bg-blue-600 text-white<% } %>">
                                <%= movie.watchStatus === 'watched' ? '✓ WATCHED' : (movie.watchStatus === 'favorite' ? '⭐ FAVORITE' : '📋 PLANNING') %>
                            </span>
                        </div>
                    </div>
                <% } else { %>
                    <div class="relative h-40 bg-gradient-to-br from-gray-700 to-gray-800 flex items-center justify-center">
                        <div class="text-center">
                            <svg class="w-12 h-12 text-gray-500 mx-auto mb-2" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M4 5h16v2H4V5zm0 4h16v2H4V9zm0 4h16v2H4v-2zm0 4h10v2H4v-2z"/>
                            </svg>
                            <p class="text-gray-500 text-xs">No poster available</p>
                        </div>
                        <div class="absolute top-3 right-3">
                            <span class="px-3 py-1.5 rounded-xl text-xs font-bold shadow-lg 
                                <% if (movie.watchStatus === 'watched') { %>bg-emerald-600 text-white
                                <% } else if (movie.watchStatus === 'favorite') { %>bg-amber-600 text-white
                                <% } else { %>bg-blue-600 text-white<% } %>">
                                <%= movie.watchStatus === 'watched' ? '✓ WATCHED' : (movie.watchStatus === 'favorite' ? '⭐ FAVORITE' : '📋 PLANNING') %>
                            </span>
                        </div>
                    </div>
                <% } %>
                
                <div class="p-6">
                    <h3 class="text-xl font-bold text-gray-200 flex-1 line-clamp-1 mb-3"><%= movie.title %></h3>
                    
                    <div class="space-y-2 mb-5">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Genre</span>
                            <span class="font-semibold text-gray-300"><%= movie.genre %></span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Year</span>
                            <span class="font-semibold text-gray-300"><%= movie.releaseYear %></span>
                        </div>
                        <div class="flex justify-between text-sm items-center">
                            <span class="text-gray-400">Rating</span>
                            <div class="flex items-center gap-1">
                                <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                <span class="font-bold text-gray-300"><%= movie.rating %></span>
                                <span class="text-gray-500">/10</span>
                            </div>
                        </div>
                        <% if (movie.overview) { %>
                            <div class="mt-3 pt-3 border-t border-gray-700">
                                <p class="text-gray-400 text-xs line-clamp-2"><%= movie.overview.length > 100 ? movie.overview.substring(0, 100) + '...' : movie.overview %></p>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="flex gap-3">
                        <a href="/movies/edit/<%= movie._id %>" class="flex-1 text-center px-4 py-2.5 bg-gray-700 text-gray-300 rounded-xl font-semibold hover:bg-purple-600 hover:text-white transition-all duration-300">
                            Edit
                        </a>
                        <form action="/movies/<%= movie._id %>?_method=DELETE" method="POST" class="flex-1">
                            <button type="submit" onclick="return confirm('Delete this movie?')" class="w-full px-4 py-2.5 bg-red-600/20 text-red-400 rounded-xl font-semibold hover:bg-red-600 hover:text-white transition-all duration-300 border border-red-600/30">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<%- include('../partials/footer') %>