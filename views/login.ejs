<%- include('partials/header') %>

<div class="min-h-[80vh] flex items-center justify-center">
    <div class="w-full max-w-md">
        <div class="bg-gray-800 rounded-2xl shadow-2xl overflow-hidden border border-gray-700">
            <div class="p-8">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-gradient-to-r from-purple-600 to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M4 5h16v2H4V5zm0 4h16v2H4V9zm0 4h16v2H4v-2zm0 4h10v2H4v-2z"/>
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">Welcome back</h2>
                    <p class="text-gray-400 text-sm mt-1">Sign in to your account</p>
                </div>
                
                <% if (success_msg) { %>
                    <div class="bg-emerald-600/20 border border-emerald-500/30 text-emerald-400 px-4 py-3 rounded-xl mb-4 text-sm"><%= success_msg %></div>
                <% } %>
                <% if (error_msg || error) { %>
                    <div class="bg-red-600/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-xl mb-4 text-sm">Invalid credentials. Please try again.</div>
                <% } %>
                
                <form action="/auth/login" method="POST">
                    <div class="mb-4">
                        <label class="block text-gray-300 text-sm font-semibold mb-2">USERNAME</label>
                        <input type="text" name="username" class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent text-white placeholder-gray-500" placeholder="@username" required>
                    </div>
                    <div class="mb-6">
                        <label class="block text-gray-300 text-sm font-semibold mb-2">PASSWORD</label>
                        <input type="password" name="password" class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent text-white placeholder-gray-500" placeholder="••••••••" required>
                    </div>
                    <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-500 text-white py-3 rounded-xl font-semibold hover:shadow-lg transition">Sign In</button>
                </form>
            </div>
            <div class="bg-gray-900/50 px-8 py-4 text-center border-t border-gray-700">
                <p class="text-sm text-gray-400">Don't have an account? <a href="/register" class="text-purple-400 font-semibold hover:underline">Create account</a></p>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>