<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MovieWatchlist | Your Cinema Universe</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- TailwindCSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        body {
            background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-900 via-gray-900 to-purple-900/20">

<!-- Dark Navigation -->
<nav class="bg-gray-900/95 backdrop-blur-md border-b border-gray-800 sticky top-0 z-50 shadow-xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-r from-purple-600 to-pink-500 rounded-xl flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M4 5h16v2H4V5zm0 4h16v2H4V9zm0 4h16v2H4v-2zm0 4h10v2H4v-2z"/>
                    </svg>
                </div>
                <span class="text-xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">MovieWatchlist</span>
            </div>
            
            <!-- Nav Links -->
            <% if (user) { %>
                <div class="hidden md:flex gap-6">
                    <a href="/movies" class="text-gray-300 hover:text-purple-400 transition font-medium">My Collection</a>
                    <a href="/movies/browse" class="text-gray-300 hover:text-purple-400 transition font-medium">Browse Movies</a>
                </div>
            <% } %>
            
            <!-- User Menu -->
            <div class="flex items-center gap-4">
                <% if (user) { %>
                    <div class="hidden md:flex items-center gap-3">
                        <div class="text-right">
                            <p class="text-sm font-semibold text-gray-200"><%= user.username %></p>
                            <p class="text-xs text-gray-400">Cinephile</p>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 flex items-center justify-center shadow-md">
                            <span class="text-white font-bold"><%= user.username.charAt(0).toUpperCase() %></span>
                        </div>
                    </div>
                    <a href="/auth/logout" class="px-4 py-2 bg-red-600/20 text-red-400 rounded-xl text-sm font-semibold hover:bg-red-600 hover:text-white transition border border-red-600/30">
                        Logout
                    </a>
                <% } else { %>
                    <a href="/login" class="px-4 py-2 border-2 border-purple-500 text-purple-400 rounded-xl text-sm font-semibold hover:bg-purple-600 hover:text-white transition">
                        Login
                    </a>
                    <a href="/register" class="px-4 py-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white rounded-xl text-sm font-semibold hover:shadow-lg transition">
                        Register
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 fade-in">